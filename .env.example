# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Google Cloud (Vertex AI + Sheets)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
GOOGLE_PROJECT_ID=your_gcp_project_id
GOOGLE_LOCATION=global
TUTOR_GEMINI_MODEL=gemini-3-flash-preview

# Google Sheets — paste IDs from your own spreadsheets (optional for local demo)
SHEET_BLOCK_1_ID=
SHEET_BLOCK_3_ID=

# SQLite journal of submissions
# TUTOR_SQLITE_ENABLED=1
# TUTOR_SQLITE_PATH=./data/tutor.db
# TUTOR_OWNER_TELEGRAM_ID=0

# Control: Gemini pass threshold for open answers (0–100)
# TUTOR_OPEN_ANSWER_PASS_SCORE=60
